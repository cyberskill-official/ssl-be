{
    "extends": "./node_modules/@cyberskill/shared/public/tsconfig.base.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "rootDir": "./src",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "paths": {
            "#modules/*": [
                "src/modules/*"
            ],
            "#shared/*": [
                "src/shared/*"
            ]
        },
        "outDir": "./build"
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "build",
        "vitest.config.ts",
        "**/*.test.ts",
        "**/*.spec.ts",
        "src/scripts"
    ]
}
