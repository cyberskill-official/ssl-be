{
    "extends": "./node_modules/@cyberskill/shared/public/tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "./src",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "paths": {
            "#modules/*": [
                "src/modules/*"
            ],
            "#shared/*": [
                "src/shared/*"
            ]
        },
        "outDir": "./build"
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ]
}
