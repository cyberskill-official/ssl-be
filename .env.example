# optional, default: development
# NODE_ENV=development

# required if NODE_ENV is production, values: staging, production
# NODE_ENV_MODE=staging

# optional, default: 8000
# PORT=8000

# optional, default: upload
# STATIC_FOLDER=upload

# optional, default: 50mb
# BODY_PARSER_LIMIT=50mb

SESSION_NAME=session-template-be-nodejs
SESSION_SECRET=session-template-be-nodejs

# optional, default: localhost
# MONGO_HOST=localhost

# optional, default: 27017
# MONGO_PORT=27017

MONGO_NAME=template-be-nodejs

# optional, default: ''
# MONGO_USERNAME=

# optional, default: ''
# MONGO_PASSWORD=

# optional, default: backup
# MONGO_BACKUP_FOLDER=backup

# optional, default: []
# CORS_WHITELIST=["http://localhost:8000"]

# optional, default: /subscriptions
# ENDPOINT_WS=/subscriptions

# optional, default: /graphql
# ENDPOINT_GRAPHQL=/graphql

# optional, default: /rest
# ENDPOINT_RESTAPI=/rest

JWT_SECRET=secret-or-public-key-min-32-chars