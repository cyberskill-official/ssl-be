{
    "name": "ssl-be",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "main": "./src/server.js",
    "scripts": {
        "build": "run-s tsc tsc:alias copy:graphql",
        "copy:graphql": "tsx src/shared/graphql/copy.ts",
        "cyberskill:ready": "cyberskill ready",
        "dev": "run-s ready migrate:up start:dev",
        "inspect": "cyberskill inspect",
        "lint": "cyberskill lint",
        "lint:fix": "cyberskill lint:fix",
        "lint:inspect": "cyberskill lint:inspect",
        "migrate:create": "cyberskill mongo:migrate:create",
        "migrate:down": "cyberskill mongo:migrate:down",
        "migrate:ready": "tsx src/shared/mongo/mongo.migrate.ts",
        "migrate:up": "cyberskill mongo:migrate:up",
        "ready": "run-s cyberskill:ready migrate:ready",
        "reset": "cyberskill reset",
        "start": "run-s ready migrate:up start:prod",
        "start:dev": "tsx watch ./src/server.ts",
        "start:prod": "tsx ./build/server.js",
        "tsc": "tsc",
        "tsc:alias": "tsc-alias -p tsconfig.json"
    },
    "dependencies": {
        "@aws-sdk/client-rekognition": "3.856.0",
        "@aws-sdk/client-sesv2": "3.856.0",
        "@bunny.net/storage-sdk": "0.3.0",
        "@cyberskill/shared": "2.5.0",
        "@graphql-tools/load-files": "7.0.1",
        "@graphql-tools/merge": "9.1.1",
        "@graphql-tools/schema": "10.0.25",
        "@graphql-tools/utils": "10.9.1",
        "axios": "1.11.0",
        "bcryptjs": "3.0.2",
        "bull": "4.16.5",
        "connect-mongo": "5.1.0",
        "countries-list": "3.1.1",
        "cron": "4.3.2",
        "date-fns": "4.1.0",
        "ejs": "3.1.10",
        "envalid": "8.1.0",
        "graphql": "16.11.0",
        "graphql-scalars": "1.24.2",
        "graphql-subscriptions": "3.0.0",
        "ioredis": "5.6.1",
        "jsonwebtoken": "9.0.2",
        "lodash-es": "4.17.21",
        "migrate-mongo": "12.1.3",
        "mongoose": "8.16.5",
        "mongoose-aggregate-paginate-v2": "1.1.4",
        "mongoose-paginate-v2": "1.9.1",
        "node-fetch": "3.3.2",
