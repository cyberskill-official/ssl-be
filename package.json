{
    "name": "ssl-be",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "main": "./src/server.js",
    "scripts": {
        "build": "run-s tsc tsc:alias copy:graphql",
        "dev": "run-s ready migrate:up start:dev",
        "lint": "cyberskill lint",
        "lint:fix": "cyberskill lint:fix",
        "lint:inspect": "cyberskill lint:inspect",
        "reset": "cyberskill reset",
        "inspect": "cyberskill inspect",
        "ready": "run-s ready:cyberskill prepare:migrate",
        "ready:cyberskill": "cyberskill ready",
        "prepare:migrate": "tsx src/modules/mongo/mongo.migrate.ts",
        "migrate": "run-s migrate:create migrate:up",
        "migrate:create": "cyberskill mongo:migrate:create",
        "migrate:down": "cyberskill mongo:migrate:down",
        "migrate:up": "cyberskill mongo:migrate:up",
        "start": "tsx ./build/server.js",
        "start:dev": "tsx watch ./src/server.ts",
        "tsc": "tsc",
        "tsc:alias": "tsc-alias -p tsconfig.json",
        "copy:graphql": "tsx src/modules/graphql/copy.ts"
    },
    "dependencies": {
        "@cyberskill/shared": "1.204.0",
        "@graphql-tools/load-files": "7.0.1",
        "@graphql-tools/merge": "9.0.24",
        "@graphql-tools/schema": "10.0.23",
        "@graphql-tools/utils": "10.8.6",
        "@sendgrid/mail": "8.1.5",
        "axios": "1.10.0",
        "bcryptjs": "3.0.2",
        "bull": "4.16.5",
        "connect-mongo": "5.1.0",
        "countries-list": "3.1.1",
        "cron": "4.3.1",
        "date-fns": "4.1.0",
        "ejs": "3.1.10",
        "envalid": "8.0.0",
        "graphql": "16.11.0",
        "graphql-scalars": "1.24.2",
        "graphql-subscriptions": "3.0.0",
        "ioredis": "5.6.1",
        "jsonwebtoken": "9.0.2",
        "lodash-es": "4.17.21",
        "migrate-mongo": "12.1.3",
        "mongoose": "8.16.1",
        "npm-run-all2": "8.0.4",
        "tsc-alias": "1.8.16",
        "tsx": "4.20.3",
        "typescript": "5.8.3",
        "validator": "13.15.15"
    },
    "devDependencies": {
        "@commitlint/cli": "19.8.1",
        "@commitlint/config-conventional": "19.8.1",
        "@eslint/config-inspector": "1.1.0",
        "@types/bull": "4.10.4",
        "@types/ejs": "3.1.5",
        "@types/express-session": "1.18.2",
        "@types/express-useragent": "1.0.5",
        "@types/fs-extra": "11.0.4",
        "@types/jsonwebtoken": "9.0.10",
        "@types/lodash-es": "4.17.12",
        "@types/node": "24.0.10",
        "@types/validator": "13.15.2",
        "eslint": "9.30.1",
        "lint-staged": "16.1.2",
        "node-modules-inspector": "1.0.0",
        "simple-git-hooks": "2.13.0"
    }
}
